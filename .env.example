# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/web3_arena

# JWT
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Blockchain
BLOCKCHAIN_RPC_URL=https://sepolia.base.org
BLOCKCHAIN_CHAIN_ID=84532
PRIVATE_KEY=your-wallet-private-key
BATTLE_ARENA_ADDRESS=
ACHIEVEMENT_NFT_ADDRESS=
ARENA_TOKEN_ADDRESS=
PLAYER_PROFILE_ADDRESS=

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Socket.IO
SOCKET_PORT=3002
SOCKET_CORS_ORIGIN=http://localhost:3000

# Monitoring (Optional)
SENTRY_DSN=
